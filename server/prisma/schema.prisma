// Stub initial — sera rempli automatiquement par `npm run db:pull`
// (introspection de la base de données existante).
//
// Workflow :
//   1. Renseigner DATABASE_URL dans .env
//   2. npm run db:pull           → remplit ce fichier depuis la DB
//   3. npm run prisma:generate   → génère le client (optionnel ici, on n'utilise pas encore le client)
//   4. npm run migrate:baseline  → marque l'état actuel comme baseline (à faire UNE fois en prod)
//
// Pour toute modif future : éditer ce fichier, puis `npm run migrate:dev -- --name <description>`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
